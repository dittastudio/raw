{
  "name": "raw",
  "type": "module",
  "private": true,
  "author": "ditta",
  "scripts": {
    "sb:login": "storyblok login",
    "sb:logout": "storyblok logout",
    "sb:help": "storyblok --help",
    "sb:components": "storyblok components pull --space 289672313529140 --verbose",
    "sb:types": "storyblok types generate --space 289672313529140 --strict",
    "sb:generate": "npm run sb:components && npm run sb:types",
    "dev": "npm run sb:generate && nuxt dev --host 0.0.0.0",
    "dev:ssl": "local-ssl-proxy --source 3010 --target 3000 --cert localhost.pem --key localhost-key.pem",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "nuke": "del-cli '.output' 'dist' '.nuxt' 'node_modules' 'package-lock.json'",
    "prepare": "husky"
  },
  "dependencies": {
    "@gohighlevel/api-client": "^2.2.2",
    "@mux/mux-node": "^12.8.1",
    "@mux/mux-player": "^3.11.7",
    "@nuxtjs/seo": "^5.1.3",
    "@pinia/nuxt": "^0.11.3",
    "@regle/nuxt": "^1.22.4",
    "@resvg/resvg-js": "^2.6.2",
    "@storyblok/nuxt": "^10.1.2",
    "@tailwindcss/vite": "^4.2.2",
    "@unhead/vue": "^2.1.13",
    "@vueuse/core": "^14.2.1",
    "gsap": "^3.15.0",
    "keen-slider": "^6.8.6",
    "lenis": "^1.3.21",
    "linkedom": "^0.18.12",
    "nuxt": "^4.4.2",
    "nuxt-gtag": "^4.1.0",
    "pinia-plugin-persistedstate": "^4.7.1",
    "postcss-nested": "^7.0.2",
    "satori": "^0.26.0",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/image": "^2.0.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "storyblok": "^4.16.8",
    "storyblok-markdown-richtext": "^1.0.3",
    "tailwind-merge": "^3.5.0",
    "typescript": "^6.0.2",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-svg-loader": "^5.1.1"
  }
